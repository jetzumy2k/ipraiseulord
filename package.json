    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.3.0",
        "@vueup/vue-quill": "^1.5.5",
        "admin-lte": "^3.2.0",
        "axios": "^1.18.1",
        "bootstrap": "^5.3.8",
        "cropperjs": "^1.6.2",
        "jquery": "^3.7.1",
        "pinia": "^3.0.4",
        "quill": "^2.0.3",
        "vue": "^3.5.39",
